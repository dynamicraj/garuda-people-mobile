{
  "name": "garuda-people-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "eas:login": "eas login",
    "eas:init": "eas init --non-interactive",
    "build:android:preview": "eas build --platform android --profile preview --non-interactive",
    "build:android:production": "eas build --platform android --profile production --non-interactive",
    "build:ios:preview": "eas build --platform ios --profile preview --non-interactive",
    "build:ios:production": "eas build --platform ios --profile production --non-interactive",
    "build:all": "eas build --platform all --profile production --non-interactive",
    "submit:android": "eas submit --platform android --latest",
    "submit:ios": "eas submit --platform ios --latest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "axios": "^1.15.0",
    "expo": "^55.0.15",
    "expo-background-fetch": "~55.0.14",
    "expo-camera": "~55.0.15",
    "expo-constants": "~55.0.14",
    "expo-device": "~55.0.15",
    "expo-file-system": "~55.0.16",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-local-authentication": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-notifications": "~55.0.19",
    "expo-secure-store": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.14",
    "expo-updates": "~55.0.20",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2",
